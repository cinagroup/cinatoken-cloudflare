# ─── 本地开发环境变量 ──────────────────────────────────
# 复制本文件为 .dev.vars 并填入实际值
# cp .dev.vars.example .dev.vars

# 应用基础
ENVIRONMENT=dev
APP_NAME=CinaToken

# Upstash Redis (开发环境可留空，本地会自动降级)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# JWT 密钥 (至少 32 字节)
JWT_SECRET=change-me-to-a-random-32-byte-string

# API Key (用于服务间调用)
API_KEY=change-me-to-a-random-api-key

# 日志级别
LOG_LEVEL=debug

# OAuth (可选)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# 支付 (可选)
# EPOCH_PAY_API_KEY=
# EPOCH_PAY_WEBHOOK_SECRET=
